name = "newsletter-bounce"
main = "src/index.ts"
compatibility_date = "2025-01-15"
compatibility_flags = ["nodejs_compat"]

# Bounce thresholds resolve from the D1 `settings` table, falling back to the
# built-in defaults in shared/settings.ts.

[[d1_databases]]
binding = "DB"
database_name = "newsletter_db"
database_id = "REPLACE_WITH_D1_ID"

[[r2_buckets]]
binding = "ARCHIVE"
bucket_name = "newsletter-archive"

# Email Routing rule (configured in the Cloudflare dashboard, on the sending
# domain — i.e. the BASE_DOMAIN setting; there is no separate bounce domain):
#   bounce+*@yourdomain.com  -> Worker `newsletter-bounce`
