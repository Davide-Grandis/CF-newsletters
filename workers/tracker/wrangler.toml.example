name = "newsletter-tracker"
main = "src/index.ts"
compatibility_date = "2025-01-15"

# Custom-domain route for the tracker (pixel, click, unsubscribe, attachment download).
# This route creates the DNS record automatically on first deploy — do NOT
# pre-create it manually or `wrangler deploy` will fail with
# "Hostname already has externally managed DNS records".
routes = [{ pattern = "track.yourdomain.com", custom_domain = true }]

[[d1_databases]]
binding = "DB"
database_name = "newsletter_db"
database_id = "REPLACE_WITH_D1_ID"

[[r2_buckets]]
binding = "ARCHIVE"
bucket_name = "newsletter-archive"

# Email Sending binding — delivers the double opt-in confirmation email for the
# public subscribe page. Requires Email Sending (DKIM) enabled on the domain.
# (The RFC 8058 mailto unsubscribe, unsubscribe+<id>@<domain>, is handled by the
# bounce worker, which already receives the catch-all inbound route.)
[[send_email]]
name = "SEND_EMAIL"

# Secrets (set via `wrangler secret put`):
#   LINK_SIGNING_KEY
#   ATTACHMENT_SIGNING_KEY
#   TURNSTILE_SECRET_KEY  — Cloudflare Turnstile secret for the public signup
#                           page (the matching site key is the TURNSTILE_SITE_KEY
#                           setting, edited from the console Settings page).
